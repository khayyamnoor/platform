{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "files": {
    "ignore": [
      "**/node_modules",
      "**/dist",
      "**/.next",
      "**/.turbo",
      "**/coverage",
      "Apps/4in1-studios-app/**",
      "Apps/ai-clone-avatar/**",
      "Apps/cinematic-ai-video-director/**",
      "Apps/dreamframe-video-studio/**",
      "Apps/dress-models-ai/**",
      "Apps/hissene-contract-classifier-(done)/**",
      "Apps/intellifeasible---sophie's-business-analysis-assistant-(done)/**",
      "Apps/logo-ideator/**",
      "Apps/lollys-product-shoot-app-(-done) (1)/**",
      "Apps/lumina-architect-ai-best-inetrior-3d-video-(done)/**",
      "Apps/minutes-of-meeting-audio-transcriber-(too-custom-(edit-template))/**",
      "Apps/stylematchai/**"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noConsoleLog": "warn"
      },
      "nursery": {
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "paths": {
              "@platform/wallet/internal-byok": "BYOK plaintext decryption is package-private. Importable only from `packages/gemini-gateway/src/clientForRequest.ts`.",
              "@google/genai": "All Gemini calls must go through the gateway. Importable only from `packages/gemini-gateway/src/clientForRequest.ts`."
            }
          }
        }
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "trailingCommas": "all",
      "semicolons": "always"
    }
  },
  "overrides": [
    {
      "include": ["apps/legacy/**", "Apps/legacy/**"],
      "formatter": { "enabled": false },
      "organizeImports": { "enabled": false },
      "linter": {
        "rules": {
          "recommended": false,
          "style": { "useImportType": "off" },
          "suspicious": { "noConsoleLog": "off" },
          "correctness": { "useExhaustiveDependencies": "off" }
        }
      }
    },
    {
      "include": ["**/clientForRequest.ts"],
      "linter": {
        "rules": {
          "nursery": {
            "noRestrictedImports": "off"
          }
        }
      }
    }
  ]
}
